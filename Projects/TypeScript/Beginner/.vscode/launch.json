{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Console",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/dist/compiled/app.js",
      "preLaunchTask": "Compile TypeScript",
      "outFiles": ["${workspaceFolder}/dist/compiled/**/*.js"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
